<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Weather Panel</title>

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#1e1e2f;
    color:white;
    text-align:center;
}

h1{
    padding:20px;
}

.container{
    display:flex;
    justify-content:center;
    gap:30px;
    flex-wrap:wrap;
    padding:20px;
}

.card{
    background:#2d2d44;
    width:250px;
    padding:25px;
    border-radius:12px;
    box-shadow:0 8px 20px rgba(0,0,0,0.4);
}

.city{
    font-size:24px;
    margin-bottom:10px;
}

.temp{
    font-size:40px;
    color:#4fc3f7;
}

.condition{
    font-size:18px;
    margin:10px 0;
}

.info{
    margin-top:10px;
    font-size:15px;
}

</style>

</head>

<body>

<h1>Current Weather</h1>

<div class="container">

<div class="card">
<div class="city">Nagpur</div>
<div class="temp">32°C</div>
<div class="condition"> Sunny</div>
<div class="info">Humidity: 45%</div>
<div class="info">Wind: 12 km/h</div>
</div>

<div class="card">
<div class="city">Mumbai</div>
<div class="temp">30°C</div>
<div class="condition"> Partly Cloudy</div>
<div class="info">Humidity: 70%</div>
<div class="info">Wind: 15 km/h</div>
</div>

<div class="card">
<div class="city">Delhi</div>
<div class="temp">28°C</div>
<div class="condition"> Cloudy</div>
<div class="info">Humidity: 55%</div>
<div class="info">Wind: 10 km/h</div>
</div>

</div>

</body>
</html>
